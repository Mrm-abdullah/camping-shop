model RentalOrder {
    id            String @id @default(uuid())
    customerId    String
    gearId        String
    quantity      Int
    startDate     DateTime
    endDate       DateTime
    totalDays     Int
    totalAmount   Float
    status        RentalStatus @default(PLACED)

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    customer       User      @relation(fields: [customerId], references: [id])
    gear           GearItem  @relation(fields: [gearId], references: [id])
    payment        Payment?

    @@index([customerId])
    @@index([gearId])
}